# Build context: services/messenger-services
# Usage: docker build -f infra/docker/Dockerfile.messenger services/messenger-services

FROM golang:1.24-alpine AS build
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN go build -o server ./cmd/server

FROM alpine:3.20
WORKDIR /app
COPY --from=build /app/server .
EXPOSE 5003
CMD ["./server"]
