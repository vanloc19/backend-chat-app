# Build context: services/api-gateway
# Usage: docker build -f infra/docker/Dockerfile.gateway services/api-gateway

FROM golang:1.24-alpine AS build
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN go build -o gateway ./cmd/server

FROM alpine:3.20
WORKDIR /app
COPY --from=build /app/gateway .
EXPOSE 5000
CMD ["./gateway"]
